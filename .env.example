# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=dashboard

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_to_a_long_random_string_min_32_chars

# ── External API ───────────────────────────────────────────────────────────────
MARKSCAN_API_BASE=https://api.markscan.co.in

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="IP House <noreply@example.com>"

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_IDLE_TIMEOUT_SECONDS=1800
