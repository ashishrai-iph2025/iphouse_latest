# ── Database ──────────────────────────────────────────────────────────────────
USE_PRODUCTION_DB=false
DB_HOST_LOCAL=localhost
DB_PORT_LOCAL=3306
DB_USER_LOCAL=root
DB_PASS_LOCAL=
DB_NAME_LOCAL=dashboard

# DB_HOST_PROD=13.222.133.205
# DB_PORT_PROD=3306
# DB_USER_PROD=...
# DB_PASS_PROD=...
# DB_NAME_PROD=...

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Must match NEXTAUTH_SECRET (or set a new strong secret here)
NEXTAUTH_SECRET=change_this_to_a_long_random_string_min_32_chars

# ── Security ──────────────────────────────────────────────────────────────────
# The session cookie is Secure (HTTPS-only) by DEFAULT. Set this only for local
# development over plain http://localhost, never in production.
# APP_ENV=development

# Peers whose X-Forwarded-For header may be trusted to carry the real client IP —
# i.e. your reverse proxy. Comma-separated IPs or CIDRs. Defaults to loopback
# (127.0.0.1/32,::1/128), which is correct when Nginx runs on the same host.
# Anything not listed here has its XFF ignored, so an attacker cannot mint a
# fresh rate-limit bucket per request by spoofing the header.
# TRUSTED_PROXIES=10.0.0.5/32

# ── External API ───────────────────────────────────────────────────────────────
MARKSCAN_API_BASE=https://api.markscan.co.in

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=IP House <noreply@example.com>

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_IDLE_TIMEOUT_SECONDS=1800

# ── Encryption (must match existing PHP/TS values) ────────────────────────────
ENCRYPTION_KEY=
API_CRED_KEY=12345678901234567890123456789012
API_CRED_IV=1234567890123456

# ── Go server port ─────────────────────────────────────────────────────────────
GO_PORT=8080
